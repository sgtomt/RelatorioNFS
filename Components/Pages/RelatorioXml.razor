@page "/relatorio-xml"
@rendermode InteractiveServer
@using nf_app_v2.Services

<div class="container py-5">
    <div class="card main-card shadow">
        <div class="card-header header-custom py-3">
            <h5 class="text-white mb-0 font-weight-bold">
                <i class="bi bi-file-earmark-spreadsheet me-2"></i>DocMiner
            </h5>
        </div>

        <div class="card-body p-4">
            <!-- Dropzone Visual -->
            <div class="upload-container position-relative p-5 text-center rounded mb-4">

                <!-- InputFile SEMPRE presente -->
                <InputFile OnChange="CarregarArquivos"
                           class="position-absolute w-100 h-100 top-0 start-0 opacity-0"
                           style="cursor: pointer;"
                           multiple accept=".xml" />

                @if (carregandoArquivos)
                {
                    <!-- Overlay por cima -->
                    <div class="position-absolute top-0 start-0 w-100 h-100 d-flex flex-column justify-content-center align-items-center bg-white bg-opacity-75">
                        <div class="spinner-border text-primary mb-2" role="status"></div>
                        <p class="fw-bold">Lendo arquivos... aguarde.</p>
                    </div>
                }
                else
                {
                    <!-- Conteúdo normal -->
                    <i class="bi bi-cloud-arrow-up upload-icon"></i>
                    <h4 class="mt-3">Arraste seus XMLs ou Clique aqui</h4>
                    <p class="text-muted small">Suporta múltiplos arquivos</p>
                }

            </div>

            @if (arquivosProntos.Any())
            {
                <div class="row align-items-center mb-3">
                    <div class="col">
                        <h6 class="mb-0 text-secondary">
                            <i class="bi bi-list-check me-2"></i>@arquivosProntos.Count arquivos na fila
                        </h6>
                    </div>
                    <div class="col-auto">
                        <button class="btn btn-sm btn-link text-danger text-decoration-none" @onclick="Limpar">
                            <i class="bi bi-trash"></i> Limpar tudo
                        </button>
                    </div>
                </div>

                <div class="file-list border shadow-sm p-2 mb-4">
                    @foreach (var arquivo in arquivosProntos)
                    {
                        <div class="d-flex align-items-center p-2 border-bottom last-child-border-0">
                            <i class="bi bi-filetype-xml text-primary fs-4 me-3"></i>
                            <div class="flex-grow-1">
                                <div class="text-truncate" style="max-width: 400px; font-weight: 500;">@arquivo.Nome</div>
                                <small class="text-muted">@((arquivo.Tamanho / 1024.0).ToString("N1")) KB</small>
                            </div>
                            <i class="bi bi-check-circle-fill text-success ms-2"></i>
                        </div>
                    }
                </div>

                <div class="d-grid shadow-sm">
                    <button class="btn btn-success btn-lg py-3 fw-bold w-100"
                            @onclick="ProcessarRelatorio"
                            disabled="@estaProcessando">

                        @if (estaProcessando)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            <span>Processando XMLs...</span>
                        }
                        else
                        {
                            <i class="bi bi-file-earmark-arrow-down-fill me-2"></i>
                            <span>GERAR EXCEL AGORA</span>
                        }
                    </button>
                </div>
            }
        </div>
    </div>
</div>

<style>

    /* Área de Upload Estilizada */
    .upload-container {
        border: 2px dashed #0d6efd;
        background-color: #f8f9fa;
        transition: all 0.3s ease;
        cursor: pointer;
    }

        .upload-container:hover {
            background-color: #e9ecef;
            border-color: #0a58ca;
        }

    /* Ícone grande para dar contexto */
    .upload-icon {
        font-size: 3rem;
        color: #0d6efd;
        opacity: 0.6;
    }

    /* Lista de Arquivos com Scroll elegante */
    .file-list {
        max-height: 250px;
        overflow-y: auto;
        border-radius: 8px;
        background: #fff;
    }

    /* Card Principal */
    .main-card {
        border: none;
        border-radius: 12px;
    }

    .header-custom {
        background: linear-gradient(90deg, #0d6efd 0%, #0a58ca 100%);
        border-radius: 12px 12px 0 0 !important;
    }

</style>

@inject IJSRuntime JS
@inject RelatorioService RelatorioService
@code {
    public class ArquivoParaProcessar
    {
        public string Nome { get; set; }
        public byte[] Conteudo { get; set; }
        public long Tamanho { get; set; }
    }

    // Mude sua lista para:
    private List<ArquivoParaProcessar> arquivosProntos = new();
    private bool carregandoArquivos = false;

    private bool estaProcessando = false;
    private async Task CarregarArquivos(InputFileChangeEventArgs e)
    {
        try
        {
            carregandoArquivos = true;
            StateHasChanged();

            // 1. Captura a lista de uma vez só (sem await aqui)
            var arquivosEnviados = e.GetMultipleFiles(1000).ToList();

            foreach (var arquivo in arquivosEnviados)
            {
                // 2. Cria o buffer e lê o arquivo IMEDIATAMENTE
                // O segredo é não deixar o loop 'respirar' antes de abrir o stream
                using var stream = arquivo.OpenReadStream(10 * 1024 * 1024);
                using var ms = new MemoryStream();
                await stream.CopyToAsync(ms);

                arquivosProntos.Add(new ArquivoParaProcessar
                    {
                        Nome = arquivo.Name,
                        Conteudo = ms.ToArray(),
                        Tamanho = arquivo.Size
                    });

                // 3. Só atualiza a tela DEPOIS que o arquivo já virou byte[]
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", "Erro ao carregar arquivos: " + ex.Message);
        }
        finally
        {
            carregandoArquivos = false;
            StateHasChanged();
        }
    }

    private void Limpar() => arquivosProntos.Clear();

    private async Task ProcessarRelatorio()
    {
        if (estaProcessando) return;
        try
        {
            estaProcessando = true;
            StateHasChanged();
            byte[] arquivofinal = await RelatorioService.GerarRelatorioAsync(arquivosProntos);
            var fileStream = new MemoryStream(arquivofinal);
            var fileName = $"Relatorio_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx";

            using var streamRef = new DotNetStreamReference(stream: fileStream);
            await JS.InvokeVoidAsync("downloadFileFromStream", fileName, streamRef);
        } 
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Erro ao processar os arquivos: {ex.Message}");
            await JS.InvokeVoidAsync("alert", "Ocorreu um erro ao processar os arquivos. Verifique o console para mais detalhes.");
        }
        finally
        {
            estaProcessando = false;
            StateHasChanged();
        }
    }
}
